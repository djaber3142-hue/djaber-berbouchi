# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSCODE: Custom override for the admin panel passcode (defaults to 1234 if not specified)
ADMIN_PASSCODE=1234

# SUPABASE CONFIGURATION: Optional for secure persistent cloud storage across deployments and GitHub updates
SUPABASE_URL=""
SUPABASE_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# FIREBASE CONFIGURATION: Highly recommended for persistent cloud database across deployments (Vercel, etc.)
FIREBASE_PROJECT_ID=""
FIREBASE_API_KEY=""
FIREBASE_APP_ID=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_DATABASE_ID="ai-studio-ab5223ce-9ebd-4023-96a2-2f1e00b93afb"
